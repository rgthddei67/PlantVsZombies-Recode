{
  "version": 6,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "toolchainFile": "D:/PVZ/vcpkg-master/scripts/buildsystems/vcpkg.cmake",
      "environment": {
        "VULKAN_SDK": "D:/VulkanSDK",
        "VSLANG": "1033"
      },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows-static"
      },
      "architecture": {
        "value": "x64",
        "strategy": "external"
      }
    },
    {
      "name": "msvc-debug",
      "displayName": "MSVC Debug (/MTd, 对应旧 Debug|x64)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_COMPILER": "cl",
        "PVZ_SHARED_RUNTIME_ROOT": "${sourceDir}/build/clang-release"
      }
    },
    {
      "name": "clang-base",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "C:/Program Files/Microsoft Visual Studio/18/Community/VC/Tools/Llvm/x64/bin/clang-cl.exe",
        "CMAKE_LINKER_TYPE": "LLD"
      },
      "vendor": {
        "microsoft.com/VisualStudioSettings/CMake/1.0": {
            "intelliSenseMode": "windows-clangcl-x64"
        }
      }
    },
    {
      "name": "clang-release",
      "displayName": "Clang Release（发布：/O2 + AVX2 + fast-math + LTO，无 PDB）",
      "inherits": "clang-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "PVZ_ENABLE_LTO": "ON"
      }
    },
    {
      "name": "clang-playtest",
      "displayName": "Clang Playtest（日常：/O2 + AVX2 + fast-math + PDB，无 LTO）",
      "inherits": "clang-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "PVZ_ENABLE_LTO": "OFF",
        "PVZ_SHARED_RUNTIME_ROOT": "${sourceDir}/build/clang-release"
      }
    }
  ],
  "buildPresets": [
    { "name": "msvc-debug", "configurePreset": "msvc-debug" },
    { "name": "clang-release", "configurePreset": "clang-release" },
    { "name": "clang-playtest", "configurePreset": "clang-playtest" }
  ]
}
