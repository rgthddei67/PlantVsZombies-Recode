  <!-- Phase 2a+: GLSL → SPIR-V 预构建。需要 glslc.exe 在 PATH 上（装 VulkanSDK 即可）。 -->
  <Target Name="CompileShaders" BeforeTargets="ClCompile" Inputs="@(ShaderSource)" Outputs="@(ShaderSource->'$(ProjectDir)Shader\spv\%(Filename).spv')">
    <MakeDir Directories="$(ProjectDir)Shader\spv" />
    <Message Importance="high" Text="[glslc] %(ShaderSource.Identity) -&gt; Shader\spv\%(ShaderSource.Filename).spv" />
    <Exec Command="glslc.exe -fshader-stage=%(ShaderSource.Stage) --target-env=vulkan1.2 -O &quot;%(ShaderSource.FullPath)&quot; -o &quot;$(ProjectDir)Shader\spv\%(ShaderSource.Filename).spv&quot;" />
  </Target>
  <ItemDefinitionGroup>
    <PostBuildEvent>
      <Command>xcopy /E /Y /I "$(ProjectDir)Shader\*.spv" "$(OutDir)Shader\"</Command>
      <Message>Copying Shader files to output directory...</Message>
    </PostBuildEvent>
  </ItemDefinitionGroup>
