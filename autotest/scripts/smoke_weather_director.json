{
  "commands": [
    { "op": "goto_level", "level": 1001 },
    { "op": "choose_cards", "cards": ["PLANT_PEASHOOTER"] },
    { "op": "wait_state", "state": "GAME", "timeout": 15 },
    { "op": "force_survival_round", "round": 20 },

    { "op": "assert_state", "path": "weather.forecastAccuracyPct", "equals": 90 },
    { "op": "assert_state", "path": "weather.newClearWeight", "equals": 0 },
    { "op": "assert_state", "path": "weather.newLightWeight", "equals": 10 },
    { "op": "assert_state", "path": "weather.newMediumWeight", "equals": 25 },
    { "op": "assert_state", "path": "weather.newHeavyWeight", "equals": 65 },
    { "op": "assert_state", "path": "weather.weakWeatherPhasesSinceHeavy", "equals": 0 },
    { "op": "assert_state", "path": "weather.heavyWeatherForced", "equals": false },

    { "op": "set_weather", "intensity": "CLEAR", "duration": 60 },
    { "op": "roll_weather_forecast", "weatherRoll": 1, "revealIn": 0.1 },
    { "op": "assert_state", "path": "weather.lockedActualIntensity", "equals": "LIGHT" },
    { "op": "assert_state", "path": "weather.forecastPlausible", "equals": true },
    { "op": "wait_seconds", "value": 0.3, "timeout": 2 },
    { "op": "assert_state", "path": "weather.intensity", "equals": "LIGHT" },
    { "op": "assert_state", "path": "weather.weakWeatherPhasesSinceHeavy", "equals": 1 },
    { "op": "assert_state", "path": "weather.remaining", "atLeast": 44, "atMost": 70 },

    { "op": "set_weather", "intensity": "CLEAR", "duration": 60 },
    { "op": "assert_state", "path": "weather.heavyWeatherForced", "equals": true },
    { "op": "roll_weather_forecast", "weatherRoll": 1, "revealIn": 0.1 },
    { "op": "assert_state", "path": "weather.lockedActualIntensity", "equals": "HEAVY" },
    { "op": "assert_state", "path": "weather.forecastPlausible", "equals": true },
    { "op": "wait_seconds", "value": 0.3, "timeout": 2 },
    { "op": "assert_state", "path": "weather.intensity", "equals": "HEAVY" },
    { "op": "assert_state", "path": "weather.weakWeatherPhasesSinceHeavy", "equals": 0 },
    { "op": "assert_state", "path": "weather.remaining", "atLeast": 84, "atMost": 150 },

    { "op": "set_weather", "intensity": "CLEAR", "duration": 60 },
    { "op": "roll_weather_forecast", "weatherRoll": 11, "revealIn": 0.1 },
    { "op": "assert_state", "path": "weather.lockedActualIntensity", "equals": "MEDIUM" },
    { "op": "wait_seconds", "value": 0.3, "timeout": 2 },
    { "op": "assert_state", "path": "weather.intensity", "equals": "MEDIUM" },
    { "op": "assert_state", "path": "weather.remaining", "atLeast": 59, "atMost": 95 },

    { "op": "set_weather", "intensity": "LIGHT", "duration": 60, "canIntensify": true },
    { "op": "advance_weather_phase", "roll": 1 },
    { "op": "assert_state", "path": "weather.intensity", "equals": "MEDIUM" },
    { "op": "assert_state", "path": "weather.remaining", "atLeast": 30, "atMost": 50 },

    { "op": "set_weather", "intensity": "LIGHT", "duration": 60, "canIntensify": true },
    { "op": "assert_state", "path": "weather.weakWeatherPhasesSinceHeavy", "equals": 1 },
    { "op": "advance_weather_phase", "roll": 31 },
    { "op": "assert_state", "path": "weather.intensity", "equals": "HEAVY" },
    { "op": "assert_state", "path": "weather.weakWeatherPhasesSinceHeavy", "equals": 0 },

    { "op": "set_weather", "intensity": "HEAVY", "duration": 60 },
    { "op": "assert_state", "path": "weather.typhoonChancePct", "equals": 95 },
    { "op": "roll_typhoon", "chanceRoll": 96, "strengthRoll": 15, "direction": "HOUSE" },
    { "op": "assert_state", "path": "weather.typhoonStrength", "equals": "NONE" },
    { "op": "assert_state", "path": "weather.typhoonChancePct", "equals": 100 },
    { "op": "roll_typhoon", "chanceRoll": 100, "strengthRoll": 15, "direction": "HOUSE" },
    { "op": "assert_state", "path": "weather.typhoonStrength", "equals": "TYPHOON" },
    { "op": "roll_typhoon", "chanceRoll": 95, "strengthRoll": 16, "direction": "HOUSE" },
    { "op": "assert_state", "path": "weather.typhoonStrength", "equals": "SEVERE" },
    { "op": "roll_typhoon", "chanceRoll": 95, "strengthRoll": 61, "direction": "FRONT" },
    { "op": "assert_state", "path": "weather.typhoonStrength", "equals": "SUPER" },

    { "op": "goto_level", "level": 10 },
    { "op": "choose_cards", "cards": ["PLANT_PEASHOOTER"] },
    { "op": "wait_state", "state": "GAME", "timeout": 15 },
    { "op": "assert_state", "path": "weather.forecastAccuracyPct", "equals": 75 },
    { "op": "assert_state", "path": "weather.newClearWeight", "equals": 15 },
    { "op": "assert_state", "path": "weather.newLightWeight", "equals": 40 },
    { "op": "assert_state", "path": "weather.newMediumWeight", "equals": 40 },
    { "op": "assert_state", "path": "weather.newHeavyWeight", "equals": 50 },
    { "op": "quit" }
  ]
}
