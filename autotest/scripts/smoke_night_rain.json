{
  "commands": [
    { "op": "goto_level", "level": 10 },
    { "op": "choose_cards", "cards": ["PLANT_ICEFUMESHROOM", "PLANT_ICESHROOM"] },
    { "op": "wait_state", "state": "GAME", "timeout": 15 },
    { "op": "set_sun", "value": 1000 },

    { "op": "set_weather", "intensity": "LIGHT", "duration": 60 },
    { "op": "wait_frames", "value": 30 },
    { "op": "assert_state", "path": "weather.intensity", "equals": "LIGHT" },
    { "op": "assert_state", "path": "weather.zombieSpeedPct", "equals": 115 },
    { "op": "assert_state", "path": "weather.plantActionSpeedPct", "equals": 110 },
    { "op": "assert_state", "path": "weather.overlayAlpha", "equals": 30 },
    { "op": "assert_state", "path": "weather.rainSoundPlaying", "equals": true },
    { "op": "screenshot", "name": "rain_light.png" },

    { "op": "set_weather", "intensity": "MEDIUM", "duration": 60 },
    { "op": "wait_frames", "value": 30 },
    { "op": "assert_state", "path": "weather.intensity", "equals": "MEDIUM" },
    { "op": "assert_state", "path": "weather.zombieSpeedPct", "equals": 125 },
    { "op": "assert_state", "path": "weather.plantActionSpeedPct", "equals": 115 },
    { "op": "assert_state", "path": "weather.overlayAlpha", "equals": 50 },
    { "op": "assert_state", "path": "weather.rainSoundPlaying", "equals": true },
    { "op": "screenshot", "name": "rain_medium.png" },

    { "op": "set_weather", "intensity": "HEAVY", "duration": 60 },
    { "op": "wait_frames", "value": 30 },
    { "op": "assert_state", "path": "weather.intensity", "equals": "HEAVY" },
    { "op": "assert_state", "path": "weather.zombieSpeedPct", "equals": 140 },
    { "op": "assert_state", "path": "weather.plantActionSpeedPct", "equals": 120 },
    { "op": "assert_state", "path": "weather.overlayAlpha", "equals": 80 },
    { "op": "assert_state", "path": "weather.rainSoundPlaying", "equals": true },
    { "op": "assert_state", "path": "weather.combinedAttackIntervalOn1500", "equals": 1250 },
    { "op": "screenshot", "name": "rain_heavy.png" },

    { "op": "add_perk", "type": "PLANT_ATTACK_SPEED", "count": 1 },
    { "op": "assert_state", "path": "weather.combinedAttackIntervalOn1500", "equals": 1087 },
    { "op": "spawn_zombie", "type": "ZOMBIE_NORMAL", "row": 0, "x": 820 },
    { "op": "assert_state", "path": "zombies.0.animExtraSpeedPct", "equals": 140 },
    { "op": "plant", "type": "PLANT_ICEFUMESHROOM", "row": 0, "col": 5 },
    { "op": "wait_seconds", "value": 3.0, "timeout": 8 },
    { "op": "assert_state", "path": "zombies.0.slowed", "equals": true },
    { "op": "assert_state", "path": "zombies.0.animExtraSpeedPct", "equals": 84 },
    { "op": "screenshot", "name": "rain_heavy_slow.png" },

    { "op": "plant", "type": "PLANT_ICESHROOM", "row": 2, "col": 2 },
    { "op": "wait_seconds", "value": 3.0, "timeout": 8 },
    { "op": "assert_state", "path": "zombies.0.frozen", "equals": true },
    { "op": "assert_state", "path": "zombies.0.animExtraSpeedPct", "equals": 0 },
    { "op": "screenshot", "name": "rain_heavy_frozen.png" },

    { "op": "trigger_lightning" },
    { "op": "assert_state", "path": "weather.screenFlashOn", "equals": true },
    { "op": "assert_state", "path": "weather.screenFlashPeakAlpha", "equals": 105 },
    { "op": "screenshot", "name": "rain_heavy_lightning.png" },
    { "op": "dump_state", "name": "state.json" },
    { "op": "set_weather", "intensity": "LIGHT", "duration": 0.2 },
    { "op": "assert_state", "path": "weather.rainSoundPlaying", "equals": true },
    { "op": "wait_seconds", "value": 0.3, "timeout": 2 },
    { "op": "assert_state", "path": "weather.intensity", "equals": "CLEAR" },
    { "op": "assert_state", "path": "weather.zombieSpeedPct", "equals": 100 },
    { "op": "assert_state", "path": "weather.rainSoundPlaying", "equals": false },

    { "op": "set_weather", "intensity": "LIGHT", "duration": 60, "canIntensify": true },
    { "op": "assert_state", "path": "weather.canIntensify", "equals": true },
    { "op": "advance_weather_phase", "roll": 31 },
    { "op": "assert_state", "path": "weather.intensity", "equals": "HEAVY" },
    { "op": "assert_state", "path": "weather.canIntensify", "equals": false },
    { "op": "assert_state", "path": "weather.rainSoundPlaying", "equals": true },
    { "op": "advance_weather_phase", "roll": 1 },
    { "op": "assert_state", "path": "weather.intensity", "equals": "MEDIUM" },
    { "op": "advance_weather_phase", "roll": 1 },
    { "op": "assert_state", "path": "weather.intensity", "equals": "LIGHT" },
    { "op": "assert_state", "path": "weather.canIntensify", "equals": false },
    { "op": "advance_weather_phase", "roll": 1 },
    { "op": "assert_state", "path": "weather.intensity", "equals": "CLEAR" },
    { "op": "assert_state", "path": "weather.rainSoundPlaying", "equals": false },

    { "op": "set_weather", "intensity": "LIGHT", "duration": 60 },
    { "op": "set_timescale", "value": 5.0 },
    { "op": "wait_seconds", "value": 28.0, "timeout": 10 },
    { "op": "assert_state", "path": "weather.intensity", "equals": "LIGHT" },
    { "op": "assert_state", "path": "weather.rainSoundPlaying", "equals": true },
    { "op": "screenshot", "name": "rain_light_after_28s.png" },
    { "op": "set_timescale", "value": 1.0 },
    { "op": "quit" }
  ]
}
