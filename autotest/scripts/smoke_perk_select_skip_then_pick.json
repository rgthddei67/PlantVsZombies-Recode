    { "op": "assert_state", "path": "perkSelect.currentPick", "equals": 0 },
    { "op": "assert_state", "path": "perkSelect.completedSteps", "equals": 2 },
    { "op": "assert_state", "path": "perkSelect.completedPicks", "equals": 1 },
