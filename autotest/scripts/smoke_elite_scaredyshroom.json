    { "op": "assert_state", "path": "plants.0.track", "equals": "anim_scaredidle" },
    { "op": "assert_state", "path": "plants.0.growthShots", "equals": 0 },
    { "op": "assert_state", "path": "plants.0.growthProgressTenths", "equals": 0 },
    { "op": "assert_state", "path": "plants.0.attackSpeedStage", "equals": 0 },
    { "op": "assert_state", "path": "plants.0.puffDamage", "equals": 10 },
    { "op": "assert_state", "path": "plants.0.shootIntervalMs", "equals": 1500 },
    { "op": "screenshot", "name": "scared_reset.png" },

    { "op": "set_spawn_paused", "value": false },
    { "op": "goto_level", "level": 1 },
    { "op": "choose_cards", "cards": ["PLANT_ELITE_SCAREDYSHROOM"] },
    { "op": "wait_state", "state": "GAME", "timeout": 15 },
    { "op": "set_sun", "value": 1000 },
    { "op": "set_spawn_paused", "value": true },
    { "op": "plant", "type": "PLANT_ELITE_SCAREDYSHROOM", "row": 2, "col": 1 },
    { "op": "wait_seconds", "value": 0.5, "timeout": 15 },
    { "op": "dump_state", "name": "day_awake.json" },
