    { "op": "assert_state", "path": "plants.0.growthRatePct", "equals": 100 },
    { "op": "spawn_zombie", "type": "ZOMBIE_REINFORCED_DOOR", "row": 2, "x": 820, "stationary": true },
    { "op": "wait_seconds", "value": 50.0, "timeout": 30 },
