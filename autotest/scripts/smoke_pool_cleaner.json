    { "op": "screenshot", "name": "pool_cleaner_leaving_water.png" },
    { "op": "wait_seconds", "value": 0.3, "timeout": 3 },
    { "op": "assert_state", "path": "mowers.2.height", "equals": "LAND" },
    { "op": "assert_state", "path": "mowers.2.track", "equals": "anim_land" },
    { "op": "assert_state", "path": "mowers.2.visualY", "atLeast": 294.4, "atMost": 294.6 },
    { "op": "dump_state", "name": "pool_cleaner_state.json" },
    { "op": "quit" }
