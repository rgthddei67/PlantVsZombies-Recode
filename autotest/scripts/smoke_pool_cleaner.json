    { "op": "assert_state", "path": "mowers.2.track", "equals": "anim_water" },
    { "op": "assert_state", "path": "mowers.2.visualY", "atLeast": 309.4, "atMost": 309.6 },
    { "op": "screenshot", "name": "pool_cleaner_in_water.png" },
