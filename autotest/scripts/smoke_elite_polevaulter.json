{
  "commands": [
    { "op": "goto_level", "level": 21 },
    { "op": "choose_cards", "cards": ["PLANT_WALLNUT"] },
    { "op": "wait_state", "state": "GAME", "timeout": 15 },
    { "op": "set_spawn_paused", "value": true },
    { "op": "set_sun", "value": 9000 },
    { "op": "set_timescale", "value": 1.0 },

    { "op": "plant", "type": "PLANT_WALLNUT", "row": 0, "col": 7 },
    { "op": "plant", "type": "PLANT_WALLNUT", "row": 0, "col": 4 },
    { "op": "plant", "type": "PLANT_WALLNUT", "row": 0, "col": 1 },
    { "op": "spawn_zombie", "type": "ZOMBIE_ELITE_POLEVAULTER", "row": 0, "x": 920 },
    { "op": "assert_state", "path": "zombieCount", "equals": 1 },
    { "op": "assert_state", "path": "zombies.0.type", "equals": "ZOMBIE_ELITE_POLEVAULTER" },
    { "op": "assert_state", "path": "zombies.0.bodyHealth", "equals": 450 },
    { "op": "assert_state", "path": "zombies.0.bodyMaxHealth", "equals": 450 },
    { "op": "assert_state", "path": "zombies.0.animExtraSpeedPct", "equals": 110 },
    { "op": "assert_state", "path": "zombies.0.vaultState", "equals": "RUNNING" },
    { "op": "assert_state", "path": "zombies.0.hasVaulted", "equals": false },
    { "op": "screenshot", "name": "elite_polevaulter_green_running.png" },
    { "op": "dump_state", "name": "elite_polevaulter_running.json" },

    { "op": "wait_seconds", "value": 0.55, "timeout": 3 },
    { "op": "assert_state", "path": "zombies.0.vaultState", "equals": "JUMPING" },
    { "op": "assert_state", "path": "zombies.0.vaultExtraDistanceAppliedOn1000", "atLeast": 1000 },
    { "op": "assert_state", "path": "zombies.0.vaultExtraDistanceAppliedOn1000", "atMost": 99000 },
    { "op": "screenshot", "name": "elite_polevaulter_mid_vault.png" },
    { "op": "dump_state", "name": "elite_polevaulter_mid_vault.json" },

    { "op": "set_timescale", "value": 5.0 },
    { "op": "wait_seconds", "value": 10.5, "timeout": 15 },
    { "op": "assert_state", "path": "zombieCount", "equals": 2 },
    { "op": "assert_state", "path": "zombies.0.type", "equals": "ZOMBIE_ELITE_POLEVAULTER" },
    { "op": "assert_state", "path": "zombies.0.vaultState", "equals": "WALKING" },
    { "op": "assert_state", "path": "zombies.0.hasVaulted", "equals": true },
    { "op": "assert_state", "path": "zombies.0.lastVaultDistanceOn1000", "equals": 250000 },
    { "op": "assert_state", "path": "zombies.0.vaultExtraDistanceAppliedOn1000", "equals": 100000 },
    { "op": "assert_state", "path": "zombies.1.type", "equals": "ZOMBIE_POLEVAULTER" },
    { "op": "screenshot", "name": "elite_polevaulter_landed_with_normal.png" },
    { "op": "dump_state", "name": "elite_polevaulter_landed.json" },

    { "op": "set_timescale", "value": 1.0 },
    { "op": "damage_zombie", "row": 0, "index": 0, "damage": 10000, "source": "OTHER", "penetrateShield": true },
    { "op": "wait_frames", "value": 8 },
    { "op": "screenshot", "name": "elite_polevaulter_green_head_drop.png" },
    { "op": "wait_seconds", "value": 4.0, "timeout": 8 },
    { "op": "assert_state", "path": "zombieCount", "equals": 1 },
    { "op": "assert_state", "path": "zombies.0.type", "equals": "ZOMBIE_POLEVAULTER" },
    { "op": "dump_state", "name": "elite_polevaulter_death_complete.json" },
    { "op": "set_spawn_paused", "value": false },
    { "op": "quit" }
  ]
}
