{
  "commands": [
    { "op": "goto_level", "level": 10 },
    { "op": "choose_cards", "cards": ["PLANT_PEASHOOTER"] },
    { "op": "wait_state", "state": "GAME", "timeout": 15 },

    { "op": "set_weather", "intensity": "CLEAR", "duration": 60.0 },
    { "op": "show_image_prompt", "image": "HUGE_WAVE" },
    { "op": "set_weather_forecast", "forecast": "HEAVY", "actual": "HEAVY", "revealIn": 5.4, "typhoonStrength": "NONE", "promptVariant": 0 },
    { "op": "assert_state", "path": "weather.pendingTyphoonPrepared", "equals": true },
    { "op": "assert_state", "path": "weather.pendingTyphoonStrength", "equals": "NONE" },
    { "op": "assert_state", "path": "weather.pendingPromptVariant", "equals": 0 },
    { "op": "assert_state", "path": "weather.heavyRainPromptShown", "equals": false },
    { "op": "wait_seconds", "value": 0.7, "timeout": 2 },
    { "op": "assert_state", "path": "weather.heavyRainPromptShown", "equals": true },
    { "op": "assert_state", "path": "prompts.activeCount", "equals": 2 },
    { "op": "assert_state", "path": "prompts.entries.0.kind", "equals": "IMAGE" },
    { "op": "assert_state", "path": "prompts.entries.1.kind", "equals": "TEXT" },
    { "op": "assert_state", "path": "prompts.entries.1.content", "equals": "玄云压城雾不开，银河倒泻雨声来" },
    { "op": "assert_state", "path": "prompts.entries.1.colorR", "equals": 112 },
    { "op": "assert_state", "path": "prompts.entries.1.colorG", "equals": 210 },
    { "op": "assert_state", "path": "prompts.entries.1.colorB", "equals": 255 },
    { "op": "screenshot", "name": "heavy_rain_no_typhoon_over_wave.png" },

    { "op": "set_weather", "intensity": "CLEAR", "duration": 60.0 },
    { "op": "wait_seconds", "value": 5.0, "timeout": 7 },
    { "op": "assert_state", "path": "prompts.activeCount", "equals": 0 },
    { "op": "set_weather_forecast", "forecast": "HEAVY", "actual": "HEAVY", "revealIn": 5.2, "typhoonStrength": "TYPHOON", "promptVariant": 0 },
    { "op": "wait_seconds", "value": 0.5, "timeout": 2 },
    { "op": "assert_state", "path": "prompts.entries.0.content", "equals": "长风卷叶穿孤城，疏雨敲窗万木鸣" },
    { "op": "assert_state", "path": "prompts.entries.0.colorR", "equals": 255 },
    { "op": "assert_state", "path": "prompts.entries.0.colorG", "equals": 205 },
    { "op": "assert_state", "path": "prompts.entries.0.colorB", "equals": 88 },
    { "op": "screenshot", "name": "heavy_rain_typhoon.png" },

    { "op": "set_weather", "intensity": "CLEAR", "duration": 60.0 },
    { "op": "wait_seconds", "value": 5.0, "timeout": 7 },
    { "op": "set_weather_forecast", "forecast": "HEAVY", "actual": "HEAVY", "revealIn": 5.2, "typhoonStrength": "SEVERE", "promptVariant": 1 },
    { "op": "wait_seconds", "value": 0.5, "timeout": 2 },
    { "op": "assert_state", "path": "weather.pendingPromptVariant", "equals": 1 },
    { "op": "assert_state", "path": "prompts.entries.0.content", "equals": "狂澜撼岳群山惊，飞石穿云万谷鸣" },
    { "op": "assert_state", "path": "prompts.entries.0.colorR", "equals": 255 },
    { "op": "assert_state", "path": "prompts.entries.0.colorG", "equals": 126 },
    { "op": "assert_state", "path": "prompts.entries.0.colorB", "equals": 66 },
    { "op": "screenshot", "name": "heavy_rain_severe_typhoon.png" },

    { "op": "set_weather", "intensity": "CLEAR", "duration": 60.0 },
    { "op": "wait_seconds", "value": 5.0, "timeout": 7 },
    { "op": "set_weather_forecast", "forecast": "HEAVY", "actual": "HEAVY", "revealIn": 5.2, "typhoonStrength": "SUPER", "promptVariant": 2 },
    { "op": "wait_seconds", "value": 0.5, "timeout": 2 },
    { "op": "assert_state", "path": "weather.pendingPromptVariant", "equals": 2 },
    { "op": "assert_state", "path": "prompts.entries.0.content", "equals": "THE END DESCENDS — ALL SHALL BREAK" },
    { "op": "assert_state", "path": "prompts.entries.0.colorR", "equals": 255 },
    { "op": "assert_state", "path": "prompts.entries.0.colorG", "equals": 60 },
    { "op": "assert_state", "path": "prompts.entries.0.colorB", "equals": 82 },
    { "op": "screenshot", "name": "heavy_rain_super_typhoon.png" },
    { "op": "wait_seconds", "value": 5.0, "timeout": 7 },
    { "op": "assert_state", "path": "weather.intensity", "equals": "HEAVY" },
    { "op": "assert_state", "path": "weather.typhoonStrength", "equals": "SUPER" },
    { "op": "assert_state", "path": "weather.pendingTyphoonPrepared", "equals": false },
    { "op": "assert_state", "path": "prompts.activeCount", "equals": 0 },

    { "op": "dump_state", "name": "state.json" },
    { "op": "quit" }
  ]
}
