{
  "commands": [
    { "op": "goto_level", "level": 19 },
    { "op": "assert_state", "path": "boardState", "equals": "CHOOSE_CARD" },
    { "op": "assert_state", "path": "background", "equals": "WATER_POOL" },
    { "op": "assert_state", "path": "rows", "equals": 6 },
    { "op": "assert_state", "path": "columns", "equals": 9 },
    { "op": "assert_state", "path": "poolRows.0", "equals": 2 },
    { "op": "assert_state", "path": "poolRows.1", "equals": 3 },
    { "op": "assert_state", "path": "supportsWeather", "equals": true },
    { "op": "assert_state", "path": "maxWave", "equals": 10 },
    { "op": "assert_state", "path": "spawnTypeCount", "equals": 2 },
    { "op": "assert_state", "path": "spawnList.0", "equals": "ZOMBIE_NORMAL" },
    { "op": "assert_state", "path": "spawnList.1", "equals": "ZOMBIE_TRAFFIC_CONE" },
    { "op": "screenshot", "name": "pool_3_1_choose_cards.png" },

    { "op": "choose_cards", "cards": ["PLANT_LILYPAD", "PLANT_PEASHOOTER", "PLANT_POTATOMINE"] },
    { "op": "wait_state", "state": "GAME", "timeout": 15 },
    { "op": "set_sun", "value": 9000 },
    { "op": "assert_state", "path": "mowerCount", "equals": 6 },
    { "op": "assert_state", "path": "mowers.2.row", "equals": 2 },
    { "op": "assert_state", "path": "mowers.2.type", "equals": "WATER" },
    { "op": "assert_state", "path": "mowers.2.height", "equals": "LAND" },
    { "op": "assert_state", "path": "mowers.2.track", "equals": "anim_land" },
    { "op": "assert_state", "path": "mowers.3.row", "equals": 3 },
    { "op": "assert_state", "path": "mowers.3.type", "equals": "WATER" },

    { "op": "assert_can_plant", "type": "PLANT_LILYPAD", "row": 0, "col": 2, "expected": false },
    { "op": "assert_can_plant", "type": "PLANT_PEASHOOTER", "row": 2, "col": 2, "expected": false },
    { "op": "assert_can_plant", "type": "PLANT_POTATOMINE", "row": 2, "col": 2, "expected": false },
    { "op": "assert_can_plant", "type": "PLANT_LILYPAD", "row": 2, "col": 2, "expected": true },
    { "op": "plant", "type": "PLANT_LILYPAD", "row": 2, "col": 2 },
    { "op": "assert_state", "path": "cells.2.2.under", "equals": "PLANT_LILYPAD" },
    { "op": "assert_state", "path": "cells.2.2.normal", "equals": "NONE" },
    { "op": "assert_state", "path": "plants.0.biteProtected", "equals": true },
    { "op": "assert_can_plant", "type": "PLANT_LILYPAD", "row": 2, "col": 2, "expected": false },
    { "op": "assert_can_plant", "type": "PLANT_PEASHOOTER", "row": 2, "col": 2, "expected": true },
    { "op": "assert_can_plant", "type": "PLANT_POTATOMINE", "row": 2, "col": 2, "expected": false },
    { "op": "plant", "type": "PLANT_PEASHOOTER", "row": 2, "col": 2 },
    { "op": "assert_state", "path": "cells.2.2.normal", "equals": "PLANT_PEASHOOTER" },
    { "op": "assert_state", "path": "cells.2.2.top", "equals": "PLANT_PEASHOOTER" },
    { "op": "wait_seconds", "value": 1.1, "timeout": 3 },
    { "op": "assert_state", "path": "plants.0.biteProtected", "equals": false },
    { "op": "screenshot", "name": "lilypad_stack_and_bob.png" },

    { "op": "set_weather", "intensity": "HEAVY", "duration": 90 },
    { "op": "assert_state", "path": "weather.intensity", "equals": "HEAVY" },
    { "op": "set_typhoon", "strength": "SEVERE", "direction": "HOUSE", "gustIn": 30, "directionIn": 30, "gustsRemaining": 1, "decayIn": 60 },
    { "op": "trigger_typhoon_gust" },
    { "op": "wait_frames", "value": 2 },
    { "op": "assert_state", "path": "cells.2.1.under", "equals": "PLANT_LILYPAD" },
    { "op": "assert_state", "path": "cells.2.1.normal", "equals": "PLANT_PEASHOOTER" },
    { "op": "assert_state", "path": "cells.2.2.top", "equals": "NONE" },
    { "op": "assert_state", "path": "weather.lastGustMovedPlants", "equals": 2 },
    { "op": "assert_state", "path": "weather.lastGustLostPlants", "equals": 0 },

    { "op": "spawn_wave_zombie", "type": "ZOMBIE_NORMAL", "mutationRoll": 100, "row": 0, "x": 850 },
    { "op": "spawn_wave_zombie", "type": "ZOMBIE_NORMAL", "mutationRoll": 100, "row": 2, "x": 850 },
    { "op": "spawn_wave_zombie", "type": "ZOMBIE_TRAFFIC_CONE", "mutationRoll": 100, "row": 3, "x": 850 },
    { "op": "spawn_wave_zombie", "type": "ZOMBIE_BUCKET", "mutationRoll": 100, "row": 2, "x": 760 },
    { "op": "wait_frames", "value": 2 },
    { "op": "assert_state", "path": "zombies.0.type", "equals": "ZOMBIE_NORMAL" },
    { "op": "assert_state", "path": "zombies.1.type", "equals": "ZOMBIE_POOL_NORMAL" },
    { "op": "assert_state", "path": "zombies.1.inPool", "equals": true },
    { "op": "assert_state", "path": "zombies.1.track", "equals": "anim_swim" },
    { "op": "assert_state", "path": "zombies.2.type", "equals": "ZOMBIE_POOL_CONE" },
    { "op": "assert_state", "path": "zombies.2.helmHealth", "equals": 370 },
    { "op": "assert_state", "path": "zombies.3.type", "equals": "ZOMBIE_POOL_BUCKET" },
    { "op": "assert_state", "path": "zombies.3.helmHealth", "equals": 1100 },
    { "op": "damage_zombie", "row": 2, "index": 0, "damage": 10000, "source": "OTHER", "penetrateShield": true },
    { "op": "wait_frames", "value": 2 },
    { "op": "assert_state", "path": "zombies.1.track", "equals": "anim_waterdeath" },
    { "op": "screenshot", "name": "pool_zombies_and_water_death.png" },
    { "op": "dump_state", "name": "pool_3_1_state.json" },

    { "op": "goto_level", "level": 20 },
    { "op": "assert_state", "path": "boardState", "equals": "CHOOSE_CARD" },
    { "op": "assert_state", "path": "background", "equals": "WATER_POOL" },
    { "op": "assert_state", "path": "rows", "equals": 6 },
    { "op": "assert_state", "path": "maxWave", "equals": 15 },
    { "op": "assert_state", "path": "spawnTypeCount", "equals": 3 },
    { "op": "assert_state", "path": "spawnList.0", "equals": "ZOMBIE_NORMAL" },
    { "op": "assert_state", "path": "spawnList.1", "equals": "ZOMBIE_TRAFFIC_CONE" },
    { "op": "assert_state", "path": "spawnList.2", "equals": "ZOMBIE_BUCKET" },
    { "op": "screenshot", "name": "pool_3_2_choose_cards.png" },
    { "op": "dump_state", "name": "pool_3_2_state.json" },
    { "op": "quit" }
  ]
}
