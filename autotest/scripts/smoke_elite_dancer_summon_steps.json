{
  "commands": [
    { "op": "goto_level", "level": 10 },
    { "op": "choose_cards", "cards": ["PLANT_PEASHOOTER"] },
    { "op": "wait_state", "state": "GAME", "timeout": 15 },
    { "op": "spawn_zombie", "type": "ZOMBIE_ELITE_DANCER", "row": 2, "x": 800 },
    { "op": "wait_seconds", "value": 0.5, "timeout": 3 },
    { "op": "assert_state", "path": "zombies.0.eliteBackupCount", "equals": 1 },
    { "op": "wait_seconds", "value": 0.5, "timeout": 3 },
    { "op": "assert_state", "path": "zombies.0.eliteBackupCount", "equals": 2 },
    { "op": "wait_seconds", "value": 0.5, "timeout": 3 },
    { "op": "assert_state", "path": "zombies.0.eliteBackupCount", "equals": 3 },
    { "op": "dump_state", "name": "state.json" },
    { "op": "quit" }
  ]
}
