{
  "commands": [
    { "op": "goto_level", "level": 1000 },
    { "op": "choose_cards", "cards": ["PLANT_PEASHOOTER"] },
    { "op": "wait_state", "state": "GAME" },
    { "op": "survival_perk_open" },
    { "op": "dump_state", "name": "perk_select_open.json" },
    { "op": "assert_state", "path": "perkSelect.active", "equals": true },
    { "op": "assert_state", "path": "perkSelect.offerCount", "equals": 3 },
    { "op": "assert_state", "path": "perkSelect.currentPick", "equals": 1 },
    { "op": "assert_state", "path": "perkSelect.completedSteps", "equals": 0 },
    { "op": "assert_state", "path": "perkSelect.completedPicks", "equals": 0 },
    { "op": "assert_state", "path": "perkSelect.maxPicks", "equals": 2 },
    { "op": "assert_state", "path": "perkSelect.refreshesRemaining", "equals": 3 },
    { "op": "assert_state", "path": "perkSelect.maxRefreshes", "equals": 3 },
    { "op": "wait_frames", "value": 30 },
    { "op": "screenshot", "name": "perk_select_first.png" },
    { "op": "click", "x": 460, "y": 420 },
    { "op": "wait_frames", "value": 30 },
    { "op": "dump_state", "name": "perk_select_first_refreshed.json" },
    { "op": "assert_state", "path": "perkSelect.currentPick", "equals": 1 },
    { "op": "assert_state", "path": "perkSelect.completedSteps", "equals": 0 },
    { "op": "assert_state", "path": "perkSelect.completedPicks", "equals": 0 },
    { "op": "assert_state", "path": "perkSelect.refreshesRemaining", "equals": 2 },
    { "op": "screenshot", "name": "perk_select_first_refreshed.png" },
    { "op": "survival_perk_pick", "index": 0 },
    { "op": "dump_state", "name": "perk_select_second.json" },
    { "op": "assert_state", "path": "perkSelect.active", "equals": true },
    { "op": "assert_state", "path": "perkSelect.offerCount", "equals": 3 },
    { "op": "assert_state", "path": "perkSelect.currentPick", "equals": 2 },
    { "op": "assert_state", "path": "perkSelect.completedSteps", "equals": 1 },
    { "op": "assert_state", "path": "perkSelect.completedPicks", "equals": 1 },
    { "op": "assert_state", "path": "perkSelect.refreshesRemaining", "equals": 2 },
    { "op": "survival_perk_refresh" },
    { "op": "survival_perk_refresh" },
    { "op": "wait_frames", "value": 30 },
    { "op": "assert_state", "path": "perkSelect.currentPick", "equals": 2 },
    { "op": "assert_state", "path": "perkSelect.completedSteps", "equals": 1 },
    { "op": "assert_state", "path": "perkSelect.completedPicks", "equals": 1 },
    { "op": "assert_state", "path": "perkSelect.refreshesRemaining", "equals": 0 },
    { "op": "screenshot", "name": "perk_select_second.png" },
    { "op": "click", "x": 460, "y": 420 },
    { "op": "assert_state", "path": "perkSelect.currentPick", "equals": 2 },
    { "op": "assert_state", "path": "perkSelect.refreshesRemaining", "equals": 0 },
    { "op": "survival_perk_pick", "index": 0 },
    { "op": "dump_state", "name": "perk_select_after.json" },
    { "op": "assert_state", "path": "perkSelect.active", "equals": false },
    { "op": "assert_state", "path": "perkSelect.offerCount", "equals": 0 },
    { "op": "assert_state", "path": "perkSelect.currentPick", "equals": 0 },
    { "op": "assert_state", "path": "perkSelect.completedSteps", "equals": 2 },
    { "op": "assert_state", "path": "perkSelect.completedPicks", "equals": 2 },
    { "op": "assert_state", "path": "perkSelect.refreshesRemaining", "equals": 0 },
    { "op": "quit" }
  ]
}
