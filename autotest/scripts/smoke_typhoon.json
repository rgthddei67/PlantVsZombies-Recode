{
  "commands": [
    { "op": "goto_level", "level": 10 },
    { "op": "choose_cards", "cards": ["PLANT_PEASHOOTER"] },
    { "op": "wait_state", "state": "GAME", "timeout": 15 },
    { "op": "set_sun", "value": 1000 },
    { "op": "set_weather", "intensity": "HEAVY", "duration": 90 },

    { "op": "plant", "type": "PLANT_PEASHOOTER", "row": 0, "col": 0 },
    { "op": "plant", "type": "PLANT_PEASHOOTER", "row": 1, "col": 4 },
    { "op": "set_typhoon", "strength": "TYPHOON", "direction": "HOUSE", "gustIn": 30, "directionIn": 30, "gustsRemaining": 2, "decayIn": 60 },
    { "op": "wait_frames", "value": 30 },
    { "op": "assert_state", "path": "weather.typhoonStrength", "equals": "TYPHOON" },
    { "op": "assert_state", "path": "weather.windDirection", "equals": "HOUSE" },
    { "op": "assert_state", "path": "weather.hostileWindMovePct", "equals": 108 },
    { "op": "assert_state", "path": "weather.charmedWindMovePct", "equals": 92 },
    { "op": "assert_state", "path": "weather.hostileCombinedMovePct", "equals": 151 },
    { "op": "assert_state", "path": "weather.charmedCombinedMovePct", "equals": 129 },
    { "op": "assert_state", "path": "weather.gustsRemaining", "equals": 0 },
    { "op": "wait_frames", "value": 45 },
    { "op": "trigger_typhoon_gust" },
    { "op": "assert_state", "path": "plantCount", "equals": 2 },
    { "op": "assert_state", "path": "weather.lastGustMovedPlants", "equals": 0 },
    { "op": "assert_state", "path": "weather.lastGustLostPlants", "equals": 0 },
    { "op": "screenshot", "name": "typhoon_no_plant_gust.png" },

    { "op": "set_typhoon", "strength": "SEVERE", "direction": "HOUSE", "gustIn": 30, "directionIn": 30, "gustsRemaining": 3, "decayIn": 60 },
    { "op": "assert_state", "path": "weather.hostileWindMovePct", "equals": 114 },
    { "op": "assert_state", "path": "weather.charmedWindMovePct", "equals": 86 },
    { "op": "assert_state", "path": "weather.hostileCombinedMovePct", "equals": 160 },
    { "op": "assert_state", "path": "weather.charmedCombinedMovePct", "equals": 120 },
    { "op": "wait_frames", "value": 60 },
    { "op": "screenshot", "name": "severe_typhoon_house_before_gust.png" },
    { "op": "trigger_typhoon_gust" },
    { "op": "wait_frames", "value": 2 },
    { "op": "assert_state", "path": "plantCount", "equals": 1 },
    { "op": "assert_state", "path": "plants.0.col", "equals": 3 },
    { "op": "assert_state", "path": "weather.lastGustMovedPlants", "equals": 1 },
    { "op": "assert_state", "path": "weather.lastGustLostPlants", "equals": 1 },
    { "op": "screenshot", "name": "severe_typhoon_house_gust_slide.png" },
    { "op": "wait_seconds", "value": 0.6, "timeout": 3 },

    { "op": "set_typhoon", "strength": "SUPER", "direction": "FRONT", "gustIn": 30, "directionIn": 30, "gustsRemaining": 2, "decayIn": 60 },
    { "op": "assert_state", "path": "weather.hostileWindMovePct", "equals": 80 },
    { "op": "assert_state", "path": "weather.charmedWindMovePct", "equals": 120 },
    { "op": "assert_state", "path": "weather.hostileCombinedMovePct", "equals": 112 },
    { "op": "assert_state", "path": "weather.charmedCombinedMovePct", "equals": 168 },
    { "op": "wait_frames", "value": 60 },
    { "op": "screenshot", "name": "super_typhoon_front_before_gust.png" },
    { "op": "trigger_typhoon_gust" },
    { "op": "assert_state", "path": "plants.0.col", "equals": 5 },
    { "op": "assert_state", "path": "weather.lastGustMovedPlants", "equals": 1 },
    { "op": "assert_state", "path": "weather.lastGustLostPlants", "equals": 0 },

    { "op": "plant", "type": "PLANT_PEASHOOTER", "row": 2, "col": 8 },
    { "op": "trigger_typhoon_gust" },
    { "op": "wait_frames", "value": 2 },
    { "op": "assert_state", "path": "plantCount", "equals": 1 },
    { "op": "assert_state", "path": "plants.0.col", "equals": 7 },
    { "op": "assert_state", "path": "weather.lastGustMovedPlants", "equals": 1 },
    { "op": "assert_state", "path": "weather.lastGustLostPlants", "equals": 1 },
    { "op": "screenshot", "name": "super_typhoon_front_after_gust.png" },
    { "op": "wait_frames", "value": 2 },

    { "op": "set_typhoon", "strength": "SUPER", "direction": "FRONT", "gustIn": 30, "directionIn": 30, "gustsRemaining": 2, "decayIn": 0.05 },
    { "op": "wait_frames", "value": 6 },
    { "op": "assert_state", "path": "weather.typhoonStrength", "equals": "SEVERE" },
    { "op": "assert_state", "path": "weather.gustsRemaining", "equals": 2 },
    { "op": "assert_state", "path": "weather.hostileWindMovePct", "equals": 86 },
    { "op": "set_typhoon", "strength": "SEVERE", "direction": "HOUSE", "gustIn": 30, "directionIn": 30, "gustsRemaining": 3, "decayIn": 0.05 },
    { "op": "wait_frames", "value": 6 },
    { "op": "assert_state", "path": "weather.typhoonStrength", "equals": "TYPHOON" },
    { "op": "assert_state", "path": "weather.gustsRemaining", "equals": 0 },
    { "op": "assert_state", "path": "weather.hostileWindMovePct", "equals": 108 },
    { "op": "set_typhoon", "strength": "TYPHOON", "direction": "HOUSE", "gustIn": 30, "directionIn": 30, "gustsRemaining": 0, "decayIn": 0.05 },
    { "op": "wait_frames", "value": 6 },
    { "op": "assert_state", "path": "weather.typhoonStrength", "equals": "NONE" },
    { "op": "assert_state", "path": "weather.windDirection", "equals": "NONE" },

    { "op": "set_weather", "intensity": "MEDIUM", "duration": 30 },
    { "op": "assert_state", "path": "weather.typhoonStrength", "equals": "NONE" },
    { "op": "assert_state", "path": "weather.windDirection", "equals": "NONE" },
    { "op": "assert_state", "path": "weather.hostileWindMovePct", "equals": 100 },
    { "op": "dump_state", "name": "state.json" },
    { "op": "quit" }
  ]
}
