#!/bin/sh
# pre-commit —— 拒绝任何缺头文件守卫(#pragma once / #ifndef)的 .h/.hpp。
#
# 背景：迁离 .sln/.vcxproj 后，VS "添加新项 → 头文件" 模板不再自动塞 #pragma once，
#       命令行/其它编辑器/工具直接写出的 .h 会漏守卫（SunShroom.h 即此例）。本钩子在
#       提交关口兜底。通过 CMake configure 期 `git config core.hooksPath .githooks` 自动启用。
#
# BOM-aware：只在文件头 512 字节内查 token 是否"存在"，不锚定 ^，故 UTF-8 BOM 前缀
#            （本仓库 BOM / 无 BOM 头文件混用）不会造成误判。读的是 staged blob，非工作树。

fail=0
for f in $(git diff --cached --name-only --diff-filter=AM -- '*.h' '*.hpp' '*.hh' '*.hxx'); do
    if ! git show ":$f" 2>/dev/null | head -c 512 | grep -qE '#pragma once|#ifndef'; then
        echo "  ✗ 缺头文件守卫: $f"
        fail=1
    fi
done

if [ "$fail" -ne 0 ]; then
    echo ""
    echo "提交被拦截：上述头文件缺少守卫。请在文件顶部(若有 BOM 则在其后)加："
    echo "    #pragma once"
    echo "  或传统双守卫：#ifndef _XXX_H / #define _XXX_H ... #endif"
    echo "（本仓库惯例：#pragma once，或 #pragma once + #ifndef 双保险）"
    exit 1
fi
exit 0
